{
  "name": "minidraco",
  "version": "0.2.0",
  "description": "A fast pure-TypeScript Draco mesh decoder, drop-in DRACOLoader replacement for Three.js.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./three": {
      "types": "./dist/three.d.ts",
      "import": "./dist/three.js"
    },
    "./three/single": {
      "types": "./dist/three-single.d.ts",
      "import": "./dist/three-single.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && cp ../README.md README.md",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "1.3.8",
    "@types/three": "^0.183.1",
    "draco.js": "mrdoob/draco.js",
    "draco3d": "1.5.7",
    "three": "^0.183.2",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "three": ">=0.170"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  }
}
